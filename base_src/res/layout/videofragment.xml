<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:orientation="vertical"
    android:id="@id/ll_todo"
    android:background="@color/com_facebook_blue"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:layout_weight="1.0"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.media3.ui.PlayerView
        android:id="@id/playerView"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        app:auto_show="false"
        app:controller_layout_id="@layout/exo_player_control_view_buscvideo"
        app:resize_mode="zoom"
        app:use_controller="false" />
    <ImageView
        android:id="@id/iv_th"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:scaleType="centerCrop" />
    <LinearLayout
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:id="@id/ll_varios"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/ll_descr"
            android:background="#99e0e0e0"
            android:padding="10.0dip"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="18.0dip"
                android:textStyle="bold"
                android:textColor="@color/textPrimaryDark"
                android:ellipsize="end"
                android:id="@id/tv_descr"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5.0dip"
                android:maxLines="2" />
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/ll_nombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5.0dip">
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@id/videoUser"
                    android:layout_width="30.0dip"
                    android:layout_height="30.0dip"
                    android:layout_marginRight="5.0dip"
                    android:layout_weight="0.0"
                    android:layout_marginEnd="5.0dip" />
                <TextView
                    android:textSize="16.0dip"
                    android:textColor="@color/textPrimaryDark"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:id="@id/tv_nombre"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:layout_marginRight="5.0dip"
                    android:maxLines="1"
                    android:layout_weight="1.0"
                    android:layout_marginEnd="5.0dip" />
                <RelativeLayout
                    android:layout_gravity="center_vertical"
                    android:id="@id/rl_playlist"
                    android:visibility="gone"
                    android:layout_width="48.0dip"
                    android:layout_height="48.0dip"
                    android:layout_weight="0.0">
                    <ImageView
                        android:layout_gravity="center_vertical"
                        android:id="@id/playlist"
                        android:layout_width="48.0dip"
                        android:layout_height="48.0dip"
                        android:layout_marginRight="5.0dip"
                        android:src="@drawable/playlist"
                        android:layout_marginEnd="5.0dip" />
                    <TextView
                        android:textSize="14.0sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimaryDark"
                        android:id="@id/playlist_badge"
                        android:background="@drawable/badge_shape"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:layout_alignParentRight="true"
                        android:fontFamily="sans-serif"
                        android:layout_alignParentEnd="true" />
                </RelativeLayout>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@id/ll_barra"
            android:background="#99757575"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/ll_likes"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4.0dip">
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@id/iv_like"
                    android:layout_width="35.0dip"
                    android:layout_height="35.0dip"
                    android:src="@drawable/like" />
                <TextView
                    android:textColor="@color/textPrimaryDark"
                    android:layout_gravity="center_vertical"
                    android:id="@id/tv_likes_n"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:fontFamily="sans-serif"
                    android:layout_marginStart="10.0dip" />
                <TextView
                    android:textColor="@color/textPrimaryDark"
                    android:layout_gravity="center_vertical"
                    android:id="@id/tv_likes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10.0dip"
                    android:layout_marginStart="10.0dip" />
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/ll_vistos"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4.0dip">
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@id/iv_vistos"
                    android:layout_width="35.0dip"
                    android:layout_height="35.0dip"
                    android:src="@drawable/eye" />
                <TextView
                    android:textColor="@color/textPrimaryDark"
                    android:layout_gravity="center_vertical"
                    android:id="@id/tv_vistos_n"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:fontFamily="sans-serif"
                    android:layout_marginStart="5.0dip"
                    android:layout_marginEnd="5.0dip" />
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/ll_coments_icon"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4.0dip">
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@id/iv_comment"
                    android:layout_width="35.0dip"
                    android:layout_height="35.0dip"
                    android:src="@drawable/comment" />
                <TextView
                    android:textColor="@color/textPrimaryDark"
                    android:layout_gravity="center_vertical"
                    android:id="@id/tv_comments_n"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:fontFamily="sans-serif"
                    android:layout_marginStart="10.0dip" />
            </LinearLayout>
            <LinearLayout
                android:gravity="end|center"
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_margin="4.0dip">
                <ImageView
                    android:id="@id/iv_reportar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/spam" />
                <ImageView
                    android:id="@id/iv_elim"
                    android:visibility="gone"
                    android:layout_width="35.0dip"
                    android:layout_height="35.0dip"
                    android:src="@drawable/eliminar" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/ll_coments_content"
            android:background="#99e0e0e0"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textStyle="bold"
                android:textColor="@color/textPrimaryDark"
                android:id="@id/tv_coments"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10.0dip"
                android:layout_marginTop="5.0dip"
                android:layout_marginBottom="10.0dip"
                android:text="@string/comentarios"
                android:layout_marginStart="10.0dip" />
            <RelativeLayout
                android:orientation="horizontal"
                android:id="@id/rl_enviarcoment"
                android:padding="6.0dip"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_gravity="center|top"
                    android:id="@id/iv_usucoment_self"
                    android:layout_width="40.0dip"
                    android:layout_height="40.0dip"
                    android:adjustViewBounds="true" />
                <LinearLayout
                    android:layout_gravity="top"
                    android:orientation="vertical"
                    android:id="@id/ll_usucoment_self"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="6.0dip"
                    android:layout_marginRight="45.0dip"
                    android:layout_toRightOf="@id/iv_usucoment_self"
                    android:layout_marginStart="6.0dip"
                    android:layout_marginEnd="45.0dip"
                    android:layout_toEndOf="@id/iv_usucoment_self">
                    <TextView
                        android:textStyle="bold"
                        android:id="@id/tv_tu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tu"
                        android:singleLine="true" />
                    <FrameLayout
                        android:orientation="horizontal"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
                        <EditText
                            android:id="@id/et_coment_self"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:maxLength="255"
                            android:inputType="textShortMessage"
                            android:textCursorDrawable="@null" />
                        <ProgressBar
                            android:layout_gravity="center_vertical"
                            android:id="@id/pb_chat_env"
                            android:visibility="gone"
                            android:layout_width="25.0dip"
                            android:layout_height="25.0dip"
                            android:layout_marginLeft="10.0dip"
                            android:layout_marginStart="10.0dip" />
                        <ProgressBar
                            android:layout_gravity="center_vertical"
                            android:id="@id/pb_chat_env_inv"
                            android:visibility="gone"
                            android:layout_width="25.0dip"
                            android:layout_height="25.0dip"
                            android:layout_marginLeft="10.0dip"
                            android:layout_marginStart="10.0dip"
                            style="@style/pb_inverse" />
                    </FrameLayout>
                </LinearLayout>
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="5.0dip"
                    android:layout_alignBottom="@id/ll_usucoment_self"
                    android:layout_alignParentRight="true"
                    android:layout_alignParentEnd="true">
                    <ImageView
                        android:id="@id/iv_enviarcom_fondo_n"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/btn_fondo_p_n" />
                    <ImageView
                        android:id="@id/iv_enviarcom_fondo_b"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/btn_fondo_p_b" />
                    <ImageView
                        android:id="@id/iv_enviarcoment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:rotationY="@integer/angle_rtl_180" />
                </FrameLayout>
            </RelativeLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@id/ll_coments"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
            <FrameLayout
                android:id="@id/fl_mascoments"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5.0dip"
                android:layout_marginTop="5.0dip"
                android:layout_marginBottom="10.0dip"
                android:layout_marginStart="5.0dip">
                <ImageView
                    android:id="@id/iv_mascoments_fondo_n"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/btn_fondo_p_n" />
                <ImageView
                    android:id="@id/iv_mascoments_fondo_b"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/btn_fondo_p_b" />
                <ImageView
                    android:id="@id/iv_mascoments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </FrameLayout>
            <ProgressBar
                android:id="@id/pb_mascoments"
                android:visibility="gone"
                android:layout_width="40.0dip"
                android:layout_height="40.0dip"
                android:layout_marginLeft="5.0dip"
                android:layout_marginTop="5.0dip"
                android:layout_marginBottom="10.0dip"
                android:layout_marginStart="5.0dip" />
            <ProgressBar
                android:id="@id/pb_mascoments_inv"
                android:visibility="gone"
                android:layout_width="40.0dip"
                android:layout_height="40.0dip"
                android:layout_marginLeft="5.0dip"
                android:layout_marginTop="5.0dip"
                android:layout_marginBottom="10.0dip"
                android:layout_marginStart="5.0dip"
                style="@style/pb_inverse" />
        </LinearLayout>
    </LinearLayout>
    <ProgressBar
        android:layout_gravity="center"
        android:id="@id/pb_global"
        android:visibility="gone"
        android:layout_width="38.0dip"
        android:layout_height="38.0dip"
        android:layout_margin="10.0dip" />
</FrameLayout>