<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/layout_root"
    android:background="@color/surfaceElevated2"
    android:padding="24.0dip"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <TextView
        android:textSize="17.0sp"
        android:textColor="@color/textPrimaryDark"
        android:fontFamily="sans-serif-medium"
        android:id="@id/message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16.0dip" />
    <EditText
        android:textSize="16.0sp"
        android:textColor="@color/textPrimaryDark"
        android:textColorHint="@color/textTertiaryDark"
        android:id="@id/et_contra"
        android:background="@drawable/bg_input_field"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:width="100.0dip"
        android:inputType="textPassword"
        android:textCursorDrawable="@null" />
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/errorRed"
        android:id="@id/message_error"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8.0dip"
        android:text="@string/contra_ko" />
    <CheckBox
        android:textStyle="normal"
        android:textColor="@color/textSecondaryDark"
        android:buttonTint="@color/colorAccent"
        android:id="@id/skip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20.0dip"
        android:text="@string/nomostrarmas" />
</LinearLayout>
