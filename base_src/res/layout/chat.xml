<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    android:id="@id/drawer_layout"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/ll_princ"
        android:background="@color/bgBase"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/amoledBlack"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="14.0dip"
            android:paddingRight="14.0dip"
            android:paddingTop="12.0dip"
            android:paddingBottom="12.0dip">
            <ImageView
                android:id="@id/iv_chat"
                android:layout_width="34.0dip"
                android:layout_height="34.0dip"
                android:layout_marginLeft="3.0dip"
                android:layout_marginRight="10.0dip"
                android:background="@drawable/bg_fab_gradient"
                android:padding="6.0dip"
                android:src="@drawable/chat" />
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textStyle="bold"
                    android:textColor="@color/textPrimaryDark"
                    android:textSize="17.0sp"
                    android:id="@id/tv_tit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tit_chat" />
                <View
                    android:id="@id/v_sep"
                    android:background="@color/glassStroke"
                    android:layout_width="fill_parent"
                    android:layout_height="1.0dip"
                    android:layout_marginTop="8.0dip" />
            </LinearLayout>
        </LinearLayout>
        <ScrollView
            android:id="@id/sv_chat"
            android:background="@color/bgBase"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_weight="1.0"
            android:scrollbars="none">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@id/llchat"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="8.0dip"
                    android:paddingBottom="8.0dip"
                    android:layout_marginLeft="8.0dip"
                    android:layout_marginStart="8.0dip" />
                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/amoledBlack"
                    android:padding="10.0dip"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
                    <FrameLayout
                        android:layout_gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_input_field"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0"
                        android:layout_marginEnd="10.0dip">
                        <EditText
                            android:layout_gravity="center_vertical"
                            android:id="@id/c_mensaje"
                            android:textColor="@color/textPrimaryDark"
                            android:textColorHint="@color/textTertiaryDark"
                            android:textSize="15.0sp"
                            android:background="@android:color/transparent"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:width="700.0dip"
                            android:maxLength="150"
                            android:inputType="textAutoCorrect|textCapSentences|textShortMessage"
                            android:textCursorDrawable="@null" />
                        <ProgressBar
                            android:layout_gravity="center_vertical|end"
                            android:id="@id/pb_chat_env"
                            android:visibility="gone"
                            android:indeterminateTint="@color/colorAccent"
                            android:layout_width="22.0dip"
                            android:layout_height="22.0dip"
                            android:layout_marginLeft="10.0dip"
                            android:layout_marginStart="10.0dip"
                            style="@style/pb_inverse" />
                    </FrameLayout>
                    <FrameLayout
                        android:layout_gravity="center_vertical"
                        android:layout_width="46.0dip"
                        android:layout_height="46.0dip">
                        <ImageView
                            android:id="@id/iv_btn_fondo_n"
                            android:visibility="gone"
                            android:layout_width="fill_parent"
                            android:layout_height="fill_parent"
                            android:background="@drawable/bg_fab_gradient"
                            android:src="@drawable/btn_fondo_p_n" />
                        <ImageView
                            android:id="@id/iv_btn_fondo_b"
                            android:visibility="gone"
                            android:layout_width="fill_parent"
                            android:layout_height="fill_parent"
                            android:background="@drawable/bg_fab_gradient"
                            android:src="@drawable/btn_fondo_p_b" />
                        <ImageView
                            android:id="@id/iv_env"
                            android:layout_width="fill_parent"
                            android:layout_height="fill_parent"
                            android:padding="12.0dip"
                            android:rotationY="@integer/angle_rtl_180" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
        <LinearLayout
            android:layout_gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@id/ll_ad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <include
            layout="@layout/bottom_menu" />
    </LinearLayout>
    <ListView
        android:layout_gravity="start"
        android:id="@id/left_drawer"
        android:background="@color/surfaceElevated"
        android:divider="@drawable/bg_divider_soft"
        android:dividerHeight="1.0dip"
        android:layout_width="260.0dip"
        android:layout_height="fill_parent"
        android:choiceMode="singleChoice" />
</androidx.drawerlayout.widget.DrawerLayout>
