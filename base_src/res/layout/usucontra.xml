<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/layout_root"
    android:background="@color/surfaceElevated2"
    android:padding="24.0dip"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="13.0sp"
            android:textColor="@color/textSecondaryDark"
            android:fontFamily="sans-serif-medium"
            android:id="@id/txtusu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6.0dip"
            android:text="@string/usuario" />
        <EditText
            android:textSize="16.0sp"
            android:textColor="@color/textPrimaryDark"
            android:id="@id/et_usu"
            android:background="@drawable/bg_input_field"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:width="140.0dip"
            android:singleLine="true"
            android:textCursorDrawable="@null" />
        <TextView
            android:textSize="13.0sp"
            android:textColor="@color/textSecondaryDark"
            android:fontFamily="sans-serif-medium"
            android:id="@id/txtcontra"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18.0dip"
            android:layout_marginBottom="6.0dip"
            android:text="@string/contra" />
        <EditText
            android:textSize="16.0sp"
            android:textColor="@color/textPrimaryDark"
            android:id="@id/et_contra"
            android:background="@drawable/bg_input_field"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:width="140.0dip"
            android:inputType="textPassword"
            android:textCursorDrawable="@null" />
    </LinearLayout>
</LinearLayout>
