<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="480dp"
                android:centerX="0.5"
                android:centerY="0.32"
                android:centerColor="@color/gradientPurpleStart"
                android:startColor="#3D7C3AED"
                android:endColor="@color/amoledBlack" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
