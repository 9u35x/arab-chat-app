<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/surfaceElevated2" />
            <corners android:radius="@dimen/app_radius_pill" />
            <stroke android:width="1.5dp" android:color="@color/colorAccent" />
            <padding android:left="18dp" android:right="18dp" android:top="12dp" android:bottom="12dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surfaceElevated" />
            <corners android:radius="@dimen/app_radius_pill" />
            <stroke android:width="1dp" android:color="@color/glassStroke" />
            <padding android:left="18dp" android:right="18dp" android:top="12dp" android:bottom="12dp" />
        </shape>
    </item>
</selector>
